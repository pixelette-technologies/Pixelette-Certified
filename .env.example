RESEND_API_KEY=re_your_resend_api_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key
CLARA_ADMIN_EMAIL=admin@yourdomain.com
CLARA_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
CLARA_RATE_LIMIT_ENABLED=true
# Set to "true" to enable /api/clara/*-test diagnostic routes. Leave as "false" or remove in production.
CLARA_DEV_ENDPOINTS_ENABLED=true
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
# Set to "true" to enable Cloudflare Turnstile CAPTCHA on first messages. Set to "false" to disable for local testing.
CLARA_TURNSTILE_ENABLED=true
